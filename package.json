{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "build": "npm run clean && npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "esbuild server/index.js --bundle --platform=node --format=esm --outfile=dist/server.js --external:vite --external:express --external:groq-sdk --external:resend --external:cors --external:dotenv --external:helmet --external:express-rate-limit",
    "start": "node dist/server.js",
    "preview": "vite preview",
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true });\"",
    "lint": "eslint ."
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.89.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.1",
    "@vitejs/plugin-react": "^5.0.4",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "firebase": "^12.13.0",
    "form-data": "^4.0.5",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^1.1.2",
    "gsap": "^3.15.0",
    "helmet": "^8.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.1.14",
    "vite": "^6.2.0"
  }
}
