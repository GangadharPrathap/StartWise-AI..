generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  firebaseUid String   @unique
  email       String   @unique
  displayName String?
  photoURL    String?
  createdAt   DateTime @default(now())

  startups    Startup[]
}

model Startup {
  id          String   @id @default(cuid())
  title       String
  description String
  industry    String?
  stage       String?

  createdAt   DateTime @default(now())

  userId      String
  user        User @relation(fields: [userId], references: [id])

  analyses    Analysis[]
}

model Analysis {
  id          String   @id @default(cuid())
  content     Json
  score       Float?

  startupId   String
  startup     Startup @relation(fields: [startupId], references: [id])

  createdAt   DateTime @default(now())
}